{
  "manifest_version": 3,
  "name": "QIE SafeSign Companion",
  "description": "Scan suspicious QIE transactions before signing. Detects phishing, unlimited approvals, and intent mismatches.",
  "version": "0.2.0",
  "icons": {
    "16": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  },
  "action": {
    "default_title": "QIE SafeSign",
    "default_popup": "popup.html",
    "default_icon": "assets/icon.svg"
  },
  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
